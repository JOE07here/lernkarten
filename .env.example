# Copy this file to `.env` and paste the values from your Firebase project:
# Firebase console → Project settings → "Your apps" → Web app → SDK config.
# These are safe to expose in a client app (Firestore security rules protect data),
# but keep .env out of git anyway.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Base path for the build. For a GitHub Pages project site use "/<repo-name>/".
# For a custom domain or user/org page, use "/".
# VITE_BASE=/lernkarten/
